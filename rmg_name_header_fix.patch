         void SetColumnHeader(int colIndex, const char * name){
+                // Update both ListView and Header control.
+                // Column 0 can fail to refresh on some comctl32 versions.
                 LVCOLUMNA lvc;
                 lvc.mask        = LVCF_TEXT;
                 lvc.iSubItem    = colIndex;
                 lvc.pszText     = const_cast<LPSTR>(name);
                 ListView_SetColumn(handle, colIndex, &lvc);
+
+                HWND hHeader = ListView_GetHeader(handle);
+                if (hHeader) {
+                        HDITEMA hdi = {};
+                        hdi.mask = HDI_TEXT;
+                        hdi.pszText = const_cast<LPSTR>(name);
+                        Header_SetItem(hHeader, colIndex, &hdi);
+                }
         }
 
